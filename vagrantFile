Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/focal64"
  
  # Script para instalação do Docker
  $install_docker = <<-SHELL
    sudo apt-get update
    curl -fsSL https://get.docker.com -o get-docker.sh
    sudo sh get-docker.sh
    sudo usermod -aG docker vagrant
  SHELL

  # Definição do Master (Manager Node)
  config.vm.define "master" do |master|
    master.vm.hostname = "master"
    master.vm.network "private_network", ip: "192.168.56.10"
    master.vm.provision "shell", inline: $install_docker
    master.vm.provision "shell", inline: <<-SHELL
      sudo docker swarm init --advertise-addr 192.168.56.10
      sudo docker swarm join-token worker -q > /vagrant/worker_token.txt
    SHELL
  end

  # Definição dos Worker Nodes (node01, node02, node03)
  (1..3).each do |i|
    config.vm.define "node0#{i}" do |node|
      node.vm.hostname = "node0#{i}"
      node.vm.network "private_network", ip: "192.168.56.1#{i}"
      node.vm.provision "shell", inline: $install_docker
      node.vm.provision "shell", inline: <<-SHELL
        TOKEN=$(cat /vagrant/worker_token.txt)
        sudo docker swarm join --token $TOKEN 192.168.56.10:2377
      SHELL
    end
  end
end
